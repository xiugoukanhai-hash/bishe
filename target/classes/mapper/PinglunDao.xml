<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.PinglunDao">
    <resultMap type="com.entity.PinglunEntity" id="pinglunMap">
        <result property="refid" column="refid"/>
        <result property="userid" column="userid"/>
        <result property="tablename" column="tablename"/>
        <result property="nickname" column="nickname"/>
        <result property="content" column="content"/>
        <result property="pingfen" column="pingfen"/>
        <result property="dingdanbianhao" column="dingdanbianhao"/>
        <result property="reply" column="reply"/>
        <result property="replytime" column="replytime"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.PinglunVO">
        SELECT * FROM pinglun pinglun
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectVO" resultType="com.entity.vo.PinglunVO">
        SELECT pinglun.* FROM pinglun pinglun
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectListView" resultType="com.entity.view.PinglunView">
        SELECT pinglun.* FROM pinglun pinglun
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectView" resultType="com.entity.view.PinglunView">
        SELECT * FROM pinglun pinglun
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>
</mapper>
