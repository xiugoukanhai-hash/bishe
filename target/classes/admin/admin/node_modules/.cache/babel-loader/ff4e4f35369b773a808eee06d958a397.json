pe":"Buffer","data":"base64:"},{"version":3,"names":["data","ruleForm","dingdanbianhao","kefanghao","kefangleixing","suoshujiudian","zhanghao","xingming","shenfenzheng","shouji","ruzhuyajin","tuifangshijian","ispay","rules","type","props","methods","init","id","_this","$http","url","concat","method","then","_ref","code","crossObj","$storage","get","crossTable","now","Date","y","getFullYear","m","getMonth","toString","padStart","d","getDate","h","getHours","min","getMinutes","s","getSeconds","remove","onSubmit","_this2","$refs","validate","valid","_ref2","$message","message","duration","onClose","parent","showFlag","addOrUpdateFlag","huiyuantuifangCrossAddOrUpdateFlag","search","error","msg","back"],"sources":["src/views/modules/huiyuantuifang/add-or-update.vue"],"sourcesContent":["<template>\n  <div class=\"addEdit-block\">\n    <el-form\n      class=\"detail-form-content\"\n      ref=\"ruleForm\"\n      :model=\"ruleForm\"\n      :rules=\"rules\"\n      label-width=\"100px\"\n    >\n      <el-row>\n        <el-col :span=\"12\">\n          <el-form-item label=\"订单编号\" prop=\"dingdanbianhao\">\n            <el-input v-model=\"ruleForm.dingdanbianhao\" placeholder=\"订单编号\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"客房号\" prop=\"kefanghao\">\n            <el-input v-model=\"ruleForm.kefanghao\" placeholder=\"客房号\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"客房类型\" prop=\"kefangleixing\">\n            <el-input v-model=\"ruleForm.kefangleixing\" placeholder=\"客房类型\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"所属酒店\" prop=\"suoshujiudian\">\n            <el-input v-model=\"ruleForm.suoshujiudian\" placeholder=\"所属酒店\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"账号\" prop=\"zhanghao\">\n            <el-input v-model=\"ruleForm.zhanghao\" placeholder=\"账号\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"姓名\" prop=\"xingming\">\n            <el-input v-model=\"ruleForm.xingming\" placeholder=\"姓名\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"身份证\" prop=\"shenfenzheng\">\n            <el-input v-model=\"ruleForm.shenfenzheng\" placeholder=\"身份证\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"手机\" prop=\"shouji\">\n            <el-input v-model=\"ruleForm.shouji\" placeholder=\"手机\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"入住押金\" prop=\"ruzhuyajin\">\n            <el-input v-model=\"ruleForm.ruzhuyajin\" placeholder=\"入住押金\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"退房时间\" prop=\"tuifangshijian\">\n            <el-date-picker v-if=\"type!='info'\" v-model=\"ruleForm.tuifangshijian\" type=\"datetime\" value-format=\"yyyy-MM-dd HH:mm:ss\" placeholder=\"选择退房时间\"></el-date-picker>\n            <el-input v-else v-model=\"ruleForm.tuifangshijian\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n      </el-row>\n      <el-form-item class=\"btn\">\n        <el-button v-if=\"type!='info'\" type=\"primary\" @click=\"onSubmit\">提交</el-button>\n        <el-button @click=\"back()\">返回</el-button>\n      </el-form-item>\n    </el-form>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      ruleForm: {\n        dingdanbianhao: '',\n        kefanghao: '',\n        kefangleixing: '',\n        suoshujiudian: '',\n        zhanghao: '',\n        xingming: '',\n        shenfenzheng: '',\n        shouji: '',\n        ruzhuyajin: '',\n        tuifangshijian: '',\n        ispay: '未支付'\n      },\n      rules: {},\n      type: ''\n    };\n  },\n  props: ['parent'],\n  methods: {\n    init(id, type) {\n      this.type = type;\n      if (id) {\n        this.$http({\n          url: `huiyuantuifang/info/${id}`,\n          method: 'get'\n        }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.ruleForm = data.data;\n          }\n        });\n      }\n      let crossObj = this.$storage.get('crossObj');\n      let crossTable = this.$storage.get('crossTable');\n      if (crossObj && (crossTable === 'huiyuanruzhu' || type === 'cross')) {\n        this.ruleForm.dingdanbianhao = crossObj.dingdanbianhao;\n        this.ruleForm.kefanghao = crossObj.kefanghao;\n        this.ruleForm.kefangleixing = crossObj.kefangleixing;\n        this.ruleForm.suoshujiudian = crossObj.suoshujiudian;\n        this.ruleForm.zhanghao = crossObj.zhanghao;\n        this.ruleForm.xingming = crossObj.xingming;\n        this.ruleForm.shenfenzheng = crossObj.shenfenzheng;\n        this.ruleForm.shouji = crossObj.shouji;\n        this.ruleForm.ruzhuyajin = crossObj.ruzhuyajin;\n        let now = new Date();\n        let y = now.getFullYear();\n        let m = (now.getMonth() + 1).toString().padStart(2, '0');\n        let d = now.getDate().toString().padStart(2, '0');\n        let h = now.getHours().toString().padStart(2, '0');\n        let min = now.getMinutes().toString().padStart(2, '0');\n        let s = now.getSeconds().toString().padStart(2, '0');\n        this.ruleForm.tuifangshijian = `${y}-${m}-${d} ${h}:${min}:${s}`;\n        this.$storage.remove('crossObj');\n        this.$storage.remove('crossTable');\n      }\n    },\n    onSubmit() {\n      this.$refs['ruleForm'].validate(valid => {\n        if (valid) {\n          this.$http({\n            url: `huiyuantuifang/${!this.ruleForm.id ? 'save' : 'update'}`,\n            method: 'post',\n            data: this.ruleForm\n          }).then(({ data }) => {\n            if (data && data.code === 0) {\n              this.$message({\n                message: '退房成功',\n                type: 'success',\n                duration: 1500,\n                onClose: () => {\n                  this.parent.showFlag = true;\n                  this.parent.addOrUpdateFlag = false;\n                  this.parent.huiyuantuifangCrossAddOrUpdateFlag = false;\n                  this.parent.search();\n                }\n              });\n            } else {\n              this.$message.error(data.msg);\n            }\n          });\n        }\n      });\n    },\n    back() {\n      this.parent.showFlag = true;\n      this.parent.addOrUpdateFlag = false;\n      this.parent.huiyuantuifangCrossAddOrUpdateFlag = false;\n    }\n  }\n};\n</script>\n<style lang=\"scss\" scoped>\n.addEdit-block {\n  padding: 20px;\n}\n.el-select {\n  width: 100%;\n}\n.btn {\n  text-align: center;\n  margin-top: 20px;\n}\n</style>\n"],"mappings":";;;;;;;AAsEA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;QACAC,cAAA;QACAC,SAAA;QACAC,aAAA;QACAC,aAAA;QACAC,QAAA;QACAC,QAAA;QACAC,YAAA;QACAC,MAAA;QACAC,UAAA;QACAC,cAAA;QACAC,KAAA;MACA;MACAC,KAAA;MACAC,IAAA;IACA;EACA;EACAC,KAAA;EACAC,OAAA;IACAC,IAAA,WAAAA,KAAAC,EAAA,EAAAJ,IAAA;MAAA,IAAAK,KAAA;MACA,KAAAL,IAAA,GAAAA,IAAA;MACA,IAAAI,EAAA;QACA,KAAAE,KAAA;UACAC,GAAA,yBAAAC,MAAA,CAAAJ,EAAA;UACAK,MAAA;QACA,GAAAC,IAAA,WAAAC,IAAA;UAAA,IAAAzB,IAAA,GAAAyB,IAAA,CAAAzB,IAAA;UACA,IAAAA,IAAA,IAAAA,IAAA,CAAA0B,IAAA;YACAP,KAAA,CAAAlB,QAAA,GAAAD,IAAA,CAAAA,IAAA;UACA;QACA;MACA;MACA,IAAA2B,QAAA,QAAAC,QAAA,CAAAC,GAAA;MACA,IAAAC,UAAA,QAAAF,QAAA,CAAAC,GAAA;MACA,IAAAF,QAAA,KAAAG,UAAA,uBAAAhB,IAAA;QACA,KAAAb,QAAA,CAAAC,cAAA,GAAAyB,QAAA,CAAAzB,cAAA;QACA,KAAAD,QAAA,CAAAE,SAAA,GAAAwB,QAAA,CAAAxB,SAAA;QACA,KAAAF,QAAA,CAAAG,aAAA,GAAAuB,QAAA,CAAAvB,aAAA;QACA,KAAAH,QAAA,CAAAI,aAAA,GAAAsB,QAAA,CAAAtB,aAAA;QACA,KAAAJ,QAAA,CAAAK,QAAA,GAAAqB,QAAA,CAAArB,QAAA;QACA,