precision=\"2\"></el-input-number>\n          </el-form-item>\n          <el-form-item v-else label=\"服务费用\"><el-input :value=\"ruleForm.fuwufeiyong?'￥'+ruleForm.fuwufeiyong:'免费'\" readonly></el-input></el-form-item>\n        </el-col>\n        <el-col :span=\"12\" v-if=\"type=='info'\">\n          <el-form-item label=\"状态\">\n            <el-tag :type=\"getStatusType(ruleForm.zhuangtai)\">{{ruleForm.zhuangtai}}</el-tag>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"24\">\n          <el-form-item v-if=\"type!='info'\" label=\"备注\" prop=\"beizhu\">\n            <el-input type=\"textarea\" :rows=\"2\" v-model=\"ruleForm.beizhu\" placeholder=\"备注信息\"></el-input>\n          </el-form-item>\n          <el-form-item v-else-if=\"ruleForm.beizhu\" label=\"备注\">\n            <el-input type=\"textarea\" :rows=\"2\" v-model=\"ruleForm.beizhu\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\" v-if=\"type=='info'\">\n          <el-form-item label=\"登记人\"><el-input v-model=\"ruleForm.dengjirenzhanghao\" readonly></el-input></el-form-item>\n        </el-col>\n        <el-col :span=\"12\" v-if=\"type=='info'\">\n          <el-form-item label=\"登记时间\"><el-input v-model=\"ruleForm.dengjishijian\" readonly></el-input></el-form-item>\n        </el-col>\n        <el-col :span=\"12\" v-if=\"type=='info' && ruleForm.chulirenzhanghao\">\n          <el-form-item label=\"处理人\"><el-input v-model=\"ruleForm.chulirenzhanghao\" readonly></el-input></el-form-item>\n        </el-col>\n        <el-col :span=\"12\" v-if=\"type=='info' && ruleForm.chulishijian\">\n          <el-form-item label=\"处理时间\"><el-input v-model=\"ruleForm.chulishijian\" readonly></el-input></el-form-item>\n        </el-col>\n      </el-row>\n      <el-form-item class=\"btn\">\n        <el-button v-if=\"type!='info'\" type=\"primary\" class=\"btn-success\" @click=\"onSubmit\">提交</el-button>\n        <el-button v-if=\"type!='info'\" class=\"btn-close\" @click=\"back()\">取消</el-button>\n        <el-button v-if=\"type=='info'\" class=\"btn-close\" @click=\"back()\">返回</el-button>\n      </el-form-item>\n    </el-form>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      id: '',\n      type: '',\n      ruleForm: { kefanghao: '', fuwuleixing: '', fuwuxiangqing: '', fuwufeiyong: 0, beizhu: '', zhuangtai: '待处理' },\n      typeOptions: ['加床服务', '早餐预订', '客房清洁', '洗衣服务', '叫醒服务', '行李寄存', '维修服务', '其他'],\n      rules: {\n        kefanghao: [{ required: true, message: '客房号不能为空', trigger: 'blur' }],\n        fuwuleixing: [{ required: true, message: '服务类型不能为空', trigger: 'change' }],\n        fuwuxiangqing: [{ required: true, message: '服务详情不能为空', trigger: 'blur' }]\n      }\n    };\n  },\n  props: [\"parent\"],\n  methods: {\n    getStatusType(status) {\n      const map = { '待处理': 'warning', '处理中': 'primary', '已完成': 'success', '已取消': 'info' };\n      return map[status] || '';\n    },\n    init(id, type) {\n      if (id) { this.id = id; this.type = type; }\n      if(this.type=='info'||this.type=='else') this.info(id);\n    },\n    info(id) {\n      this.$http({ url: `fuwujilu/info/${id}`, method: \"get\" }).then(({ data }) => {\n        if (data && data.code === 0) { this.ruleForm = data.data; }\n        else { this.$message.error(data.msg); }\n      });\n    },\n    onSubmit() {\n      this.$refs[\"ruleForm\"].validate(valid => {\n        if (valid) {\n          this.$http({ url: `fuwujilu/${!this.ruleForm.id ? \"save\" : \"update\"}`, method: \"post\", data: this.ruleForm }).then(({ data }) => {\n            if (data && data.code === 0) {\n              this.$message({ message: \"操作成功\", type: \"success\", duration: 1500, onClose: () => {\n                this.parent.showFlag = true;\n                this.parent.addOrUpdateFlag = false;\n                this.parent.search();\n              }});\n            } else { this.$message.error(data.msg); }\n          });\n        }\n      });\n    },\n    back() { this.parent.showFlag = true; this.parent.addOrUpdateFlag = false; this.parent.contentStyleChange(); }\n  }\n};\n</script>\n<style lang=\"scss\">\n.addEdit-block { margin: -10px; }\n.detail-form-content { padding: 12px; }\n.btn .el-button { padding: 0 20px; }\n</style>\n"],"mappings":";;AAmEA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,EAAA;MACAC,IAAA;MACAC,QAAA;QAAAC,SAAA;QAAAC,WAAA;QAAAC,aAAA;QAAAC,WAAA;QAAAC,MAAA;QAAAC,SAAA;MAAA;MACAC,WAAA;MACAC,KAAA;QACAP,SAAA;UAAAQ,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAT,WAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAR,aAAA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,KAAA;EACAC,OAAA;IACAC,aAAA,WAAAA,cAAAC,MAAA;MACA,IAAAC,GAAA;QAAA;QAAA;QAAA;QAAA;MAAA;MACA,OAAAA,GAAA,CAAAD,MAAA;IACA;IACAE,IAAA,WAAAA,KAAAnB,EAAA,EAAAC,IAAA;MACA,IAAAD,EAAA;QAAA,KAAAA,EAAA,GAAAA,EAAA;QAAA,KAAAC,IAAA,GAAAA,IAAA;MAAA;MACA,SAAAA,IAAA,mBAAAA,IAAA,iBAAAmB,IAAA,CAAApB,EAAA;IACA;IACAoB,IAAA,WAAAA,KAAApB,EAAA;MAAA,IAAAqB,KAAA;MACA,KAAAC,KAAA;QAAAC,GAAA,mBAAAC,MAAA,CAAAxB,EAAA;QAAAyB,MAAA;MAAA,GAAAC,IAAA,WAAAC,IAAA;QAAA,IAAA5B,IAAA,GAAA4B,IAAA,CAAA5B,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA,CAAA6B,IAAA;UAAAP,KAAA,CAAAnB,QAAA,GAAAH,IAAA,CAAAA,IAAA;QAAA,OACA;UAAAsB,KAAA,CAAAQ,QAAA,CAAAC,KAAA,CAAA/B,IAAA,CAAAgC,GAAA;QAAA;MACA;IACA;IACAC,QAAA,WAAAA,SAAA;MAAA,IAAAC,MAAA;MACA,KAAAC,KAAA,aAAAC,QAAA,WAAAC,KAAA;QACA,IAAAA,KAAA;UACAH,MAAA,CAAAX,KAAA;YAAAC,GAAA,cAAAC,MAAA,EAAAS,MAAA,CAAA/B,QAAA,CAAAF,EAAA;YAAAyB,MAAA;YAAA1B,IAAA,EAAAkC,MAAA,CAAA/B;UAAA,GAAAwB,IAAA,WAAAW,KAAA;YAAA,IAAAtC,IAAA,GAAAsC,KAAA,CAAAtC,IAAA;YACA,IAAAA,IAAA,IAAAA,IAAA,CAAA6B,IAAA;cACAK,MAAA,CAAAJ,QAAA;gBAAAjB,OAAA;gBAAAX,IAAA;gBAAAqC,QAAA;gBAAAC,OAAA,WAAAA,QAAA;kBACAN,MAAA,CAAAO,MAAA,CAAAC,QAAA;kBACAR,MAAA,CAAAO,MAAA,CAAAE,eAAA;kBACAT,MAAA,CAAAO,MAAA,CAAAG,MAAA;gBACA;cAAA;YACA;cAAAV,MAAA,CAAAJ,QAAA,CAAAC,KAAA,CAAA/B,IAAA,CAAAgC,GAAA;YAAA;UACA;QACA;MACA;IACA;IACAa,IAAA,WAAAA,KAAA;MAAA,KAAAJ,MAAA,CAAAC,QAAA;MAAA,KAAAD,MAAA,CAAAE,eAAA;MAAA,KAAAF,MAAA,CAAAK,kBAAA;IAAA;EACA;AACA","ignoreList":[]}]}