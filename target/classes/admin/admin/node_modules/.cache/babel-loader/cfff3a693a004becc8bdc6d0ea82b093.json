{"remainingRequest":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\thread-loader\\dist\\cjs.js!C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\src\\views\\qiantai\\checkin.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\src\\views\\qiantai\\checkin.vue","mtime":1772517846571},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\babel.config.js","mtime":1619749916000},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772463534547},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1772452301944},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\babel-loader\\lib\\index.js","mtime":1772463536467},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772463534547},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\vue-loader\\lib\\index.js","mtime":1772452305034}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,