column>\r\n          <el-table-column sortable align=\"center\" prop=\"louceng\" header-align=\"center\" label=\"??\" width=\"80\">\r\n            <template slot-scope=\"scope\">{{scope.row.louceng || '-'}}</template>\r\n          </el-table-column>\r\n          <el-table-column sortable align=\"center\" prop=\"chuangxing\" header-align=\"center\" label=\"??\" width=\"100\">\r\n            <template slot-scope=\"scope\">{{scope.row.chuangxing}}</template>\r\n          </el-table-column>\r\n          <el-table-column sortable align=\"center\" prop=\"suoshujiudian\" header-align=\"center\" label=\"????\">\r\n            <template slot-scope=\"scope\">{{scope.row.suoshujiudian}}</template>\r\n          </el-table-column>\r\n          <el-table-column align=\"center\" prop=\"kefangzhuangtai\" header-align=\"center\" label=\"????\" width=\"100\">\r\n            <template slot-scope=\"scope\">\r\n              <el-tag :type=\"scope.row.kefangzhuangtai=='???'?'warning':'info'\">{{scope.row.kefangzhuangtai}}</el-tag>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column align=\"center\" prop=\"weishengqingkuang\" header-align=\"center\" label=\"????\" width=\"100\">\r\n            <template slot-scope=\"scope\">\r\n              <el-tag :type=\"scope.row.weishengqingkuang=='???'?'danger':'success'\">{{scope.row.weishengqingkuang}}</el-tag>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column width=\"200\" align=\"center\" header-align=\"center\" label=\"??\">\r\n            <template slot-scope=\"scope\">\r\n              <el-button v-if=\"isAuth('daiqingsao','??')\" type=\"info\" icon=\"el-icon-view\" size=\"mini\" @click=\"viewDetail(scope.row)\">??</el-button>\r\n              <el-button v-if=\"isAuth('daiqingsao','??')\" type=\"success\" icon=\"el-icon-check\" size=\"mini\" @click=\"cleanRoom(scope.row)\">??</el-button>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>