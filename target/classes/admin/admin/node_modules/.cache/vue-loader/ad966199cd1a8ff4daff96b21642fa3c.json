{"remainingRequest":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\src\\views\\modules\\daiqingsao\\list.vue?vue&type=style&index=0&id=e06ff46a&prod&lang=scss&scoped=true","dependencies":[{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\src\\views\\modules\\daiqingsao\\list.vue","mtime":1772461523035},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\css-loader\\dist\\cjs.js","mtime":1772463535432},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1772452306115},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\postcss-loader\\src\\index.js","mtime":1772463536442},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1772452301945},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772463534547},{"path":"C:\\Users\\10606\\Desktop\\jiudianguanli\\springboot6alf1\\src\\main\\resources\\admin\\admin\\node_modules\\vue-loader\\lib\\index.js","mtime":1772452305034}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["list.vue"],"names":[],"mappings":";AA6PA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"list.vue","sourceRoot":"src/views/modules/daiqingsao","sourcesContent":["<template>\n  <div class=\"main-content\">\n    <!-- 待清扫房间列表页 -->\n    <div v-if=\"showFlag\">\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"form-content\">\n        <el-row :gutter=\"20\" class=\"slt\" :style=\"{justifyContent:'flex-start'}\">\n          <el-form-item label=\"客房号\">\n            <el-input prefix-icon=\"el-icon-search\" v-model=\"searchForm.kefanghao\" placeholder=\"客房号\" clearable></el-input>\n          </el-form-item>\n          <el-form-item label=\"客房类型\">\n            <el-input prefix-icon=\"el-icon-search\" v-model=\"searchForm.kefangleixing\" placeholder=\"客房类型\" clearable></el-input>\n          </el-form-item>\n          <el-form-item>\n            <el-button icon=\"el-icon-search\" type=\"success\" @click=\"search()\">查询</el-button>\n            <el-button icon=\"el-icon-refresh\" type=\"info\" @click=\"resetSearch()\">重置</el-button>\n          </el-form-item>\n        </el-row>\n        <el-row class=\"ad\">\n          <el-form-item>\n            <el-tag type=\"warning\" size=\"medium\" style=\"margin-right:10px;\">\n              <i class=\"el-icon-warning\"></i> 待清扫房间数量: {{ totalPage }}\n            </el-tag>\n          </el-form-item>\n        </el-row>\n      </el-form>\n      <div class=\"table-content\">\n        <el-table class=\"tables\" size=\"medium\" :show-header=\"true\"\n            border\n            fit\n            stripe\n            :style=\"{width: '100%',fontSize:'14px'}\"\n            v-if=\"isAuth('daiqingsao','查看')\"\n            :data=\"dataList\"\n            v-loading=\"dataListLoading\">\n            <el-table-column label=\"序号\" type=\"index\" width=\"60\" align=\"center\" />\n            <el-table-column sortable align=\"center\"\n                prop=\"kefanghao\"\n                header-align=\"center\"\n                label=\"客房号\"\n                width=\"120\">\n              <template slot-scope=\"scope\">\n                <el-tag type=\"primary\">{{scope.row.kefanghao}}</el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column sortable align=\"center\"\n                prop=\"kefangleixing\"\n                header-align=\"center\"\n                label=\"客房类型\"\n                width=\"120\">\n              <template slot-scope=\"scope\">\n                {{scope.row.kefangleixing}}\n              </template>\n            </el-table-column>\n            <el-table-column sortable align=\"center\"\n                prop=\"louceng\"\n                header-align=\"center\"\n                label=\"楼层\"\n                width=\"80\">\n              <template slot-scope=\"scope\">\n                {{scope.row.louceng || '-'}}\n              </template>\n            </el-table-column>\n            <el-table-column sortable align=\"center\"\n                prop=\"chuangxing\"\n                header-align=\"center\"\n                label=\"床型\"\n                width=\"100\">\n              <template slot-scope=\"scope\">\n                {{scope.row.chuangxing}}\n              </template>\n            </el-table-column>\n            <el-table-column sortable align=\"center\"\n                prop=\"suoshujiudian\"\n                header-align=\"center\"\n                label=\"所属酒店\">\n              <template slot-scope=\"scope\">\n                {{scope.row.suoshujiudian}}\n              </template>\n            </el-table-column>\n            <el-table-column align=\"center\"\n                prop=\"kefangzhuangtai\"\n                header-align=\"center\"\n                label=\"房间状态\"\n                width=\"100\">\n              <template slot-scope=\"scope\">\n                <el-tag :type=\"scope.row.kefangzhuangtai=='待清扫'?'warning':'info'\">\n                  {{scope.row.kefangzhuangtai}}\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column align=\"center\"\n                prop=\"weishengqingkuang\"\n                header-align=\"center\"\n                label=\"卫生情况\"\n                width=\"100\">\n              <template slot-scope=\"scope\">\n                <el-tag :type=\"scope.row.weishengqingkuang=='待清扫'?'danger':'success'\">\n                  {{scope.row.weishengqingkuang}}\n                </el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column width=\"200\" align=\"center\"\n                header-align=\"center\"\n                label=\"操作\">\n                <template slot-scope=\"scope\">\n                  <el-button v-if=\"isAuth('daiqingsao','查看')\" type=\"info\" icon=\"el-icon-view\" size=\"mini\" @click=\"viewDetail(scope.row)\">详情</el-button>\n                  <el-button v-if=\"isAuth('daiqingsao','清扫')\" type=\"success\" icon=\"el-icon-check\" size=\"mini\" @click=\"cleanRoom(scope.row)\">清扫</el-button>\n                </template>\n            </el-table-column>\n        </el-table>\n        <el-pagination\n          :layout=\"'total, sizes, prev, pager, next, jumper'\"\n          @size-change=\"sizeChangeHandle\"\n          @current-change=\"currentChangeHandle\"\n          :current-page=\"pageIndex\"\n          :page-sizes=\"[10, 20, 50, 100]\"\n          :page-size=\"pageSize\"\n          :total=\"totalPage\"\n          class=\"pagination-content\"\n          background\n          style=\"text-align:right;margin-top:15px;\"\n        ></el-pagination>\n      </div>\n    </div>\n    <!-- 房间详情弹窗 -->\n    <el-dialog title=\"房间详情\" :visible.sync=\"detailVisible\" width=\"600px\">\n      <el-descriptions :column=\"2\" border v-if=\"currentRoom\">\n        <el-descriptions-item label=\"客房号\">{{currentRoom.kefanghao}}</el-descriptions-item>\n        <el-descriptions-item label=\"客房类型\">{{currentRoom.kefangleixing}}</el-descriptions-item>\n        <el-descriptions-item label=\"床型\">{{currentRoom.chuangxing}}</el-descriptions-item>\n        <el-descriptions-item label=\"楼层\">{{currentRoom.louceng || '-'}}</el-descriptions-item>\n        <el-descriptions-item label=\"房间面积\">{{currentRoom.fangjianmianji}}</el-descriptions-item>\n        <el-descriptions-item label=\"价格\">{{currentRoom.jiage}}</el-descriptions-item>\n        <el-descriptions-item label=\"房间状态\">\n          <el-tag :type=\"currentRoom.kefangzhuangtai=='待清扫'?'warning':'info'\">{{currentRoom.kefangzhuangtai}}</el-tag>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"卫生情况\">\n          <el-tag :type=\"currentRoom.weishengqingkuang=='待清扫'?'danger':'success'\">{{currentRoom.weishengqingkuang}}</el-tag>\n        </el-descriptions-item>\n        <el-descriptions-item label=\"所属酒店\" :span=\"2\">{{currentRoom.suoshujiudian}}</el-descriptions-item>\n        <el-descriptions-item label=\"客房环境\" :span=\"2\">{{currentRoom.kefanghuanjing || '-'}}</el-descriptions-item>\n      </el-descriptions>\n      <div slot=\"footer\">\n        <el-button @click=\"detailVisible = false\">关闭</el-button>\n        <el-button type=\"success\" icon=\"el-icon-check\" @click=\"cleanRoom(currentRoom)\">立即清扫</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      searchForm: {\n        kefanghao: \"\",\n        kefangleixing: \"\"\n      },\n      dataList: [],\n      pageIndex: 1,\n      pageSize: 10,\n      totalPage: 0,\n      dataListLoading: false,\n      showFlag: true,\n      detailVisible: false,\n      currentRoom: null\n    };\n  },\n  created() {\n    this.getDataList();\n  },\n  methods: {\n    search() {\n      this.pageIndex = 1;\n      this.getDataList();\n    },\n    resetSearch() {\n      this.searchForm = {\n        kefanghao: \"\",\n        kefangleixing: \"\"\n      };\n      this.search();\n    },\n    getDataList() {\n      this.dataListLoading = true;\n      let params = {\n        page: this.pageIndex,\n        limit: this.pageSize,\n        sort: 'id',\n      }\n      if(this.searchForm.kefanghao) {\n        params['kefanghao'] = '%' + this.searchForm.kefanghao + '%'\n      }\n      if(this.searchForm.kefangleixing) {\n        params['kefangleixing'] = '%' + this.searchForm.kefangleixing + '%'\n      }\n      this.$http({\n        url: \"daiqingsao/page\",\n        method: \"get\",\n        params: params\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.dataList = data.data.list;\n          this.totalPage = data.data.total;\n        } else {\n          this.dataList = [];\n          this.totalPage = 0;\n        }\n        this.dataListLoading = false;\n      });\n    },\n    sizeChangeHandle(val) {\n      this.pageSize = val;\n      this.pageIndex = 1;\n      this.getDataList();\n    },\n    currentChangeHandle(val) {\n      this.pageIndex = val;\n      this.getDataList();\n    },\n    viewDetail(row) {\n      this.currentRoom = row;\n      this.detailVisible = true;\n    },\n    cleanRoom(row) {\n      this.$confirm(`确定将房间 ${row.kefanghao} 标记为已清扫吗?`, \"清扫确认\", {\n        confirmButtonText: \"确定清扫\",\n        cancelButtonText: \"取消\",\n        type: \"warning\"\n      }).then(() => {\n        this.$http({\n          url: `daiqingsao/clean/${row.id}`,\n          method: \"post\"\n        }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.$message({\n              message: data.msg || \"清扫完成\",\n              type: \"success\",\n              duration: 1500,\n              onClose: () => {\n                this.detailVisible = false;\n                this.getDataList();\n              }\n            });\n          } else {\n            this.$message.error(data.msg || \"操作失败\");\n          }\n        });\n      }).catch(() => {});\n    }\n  }\n};\n</script>\n<style lang=\"scss\" scoped>\n.slt {\n  margin: 0 !important;\n  display: flex;\n}\n.ad {\n  margin: 0 !important;\n  display: flex;\n}\n.tables {\n  & /deep/ .el-button--success {\n    background-color: #67c23a;\n    border-color: #67c23a;\n    color: #fff;\n  }\n  & /deep/ .el-button--info {\n    background-color: #909399;\n    border-color: #909399;\n    color: #fff;\n  }\n  & /deep/ .el-button {\n    margin: 4px;\n  }\n}\n</style>\n"]}]}