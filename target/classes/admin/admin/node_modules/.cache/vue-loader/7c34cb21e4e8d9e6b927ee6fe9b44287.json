"form-content\">\n        <el-row :gutter=\"20\" class=\"slt\">\n          <el-form-item label=\"???\">\n            <el-input prefix-icon=\"el-icon-search\" v-model=\"searchForm.kefanghao\" placeholder=\"???\" clearable></el-input>\n          </el-form-item>\n          <el-form-item label=\"??\">\n            <el-input prefix-icon=\"el-icon-search\" v-model=\"searchForm.xingming\" placeholder=\"??\" clearable></el-input>\n          </el-form-item>\n          <el-form-item>\n            <el-button icon=\"el-icon-search\" type=\"success\" @click=\"search()\">??</el-button>\n          </el-form-item>\n        </el-row>\n        <el-row class=\"ad\">\n          <el-form-item>\n            <el-button v-if=\"isAuth('yonghuquxiao','??')\" type=\"success\" icon=\"el-icon-plus\" @click=\"addOrUpdateHandler()\">??</el-button>\n            <el-button v-if=\"isAuth('yonghuquxiao','??')\" :disabled=\"dataListSelections.length <= 0\" type=\"danger\" icon=\"el-icon-delete\" @click=\"deleteHandler()\">????</el-button>\n          </el-form-item>\n        </el-row>\n      </el-form>\n      <div class=\"table-content\">\n        <el-table class=\"tables\" size=\"medium\" border stripe v-if=\"isAuth('yonghuquxiao','??')\" :data=\"dataList\" v-loading=\"dataListLoading\" @selection-change=\"selectionChangeHandler\">\n          <el-table-column type=\"selection\" header-align=\"center\" align=\"center\" width=\"50\"></el-table-column>\n          <el-table-column label=\"??\" type=\"index\" width=\"50\" align=\"center\"></el-table-column>\n          <el-table-column prop=\"yuyuebianhao\" header-align=\"center\" align=\"center\" label=\"????\"></el-table-column>\n          <el-table-column prop=\"kefanghao\" header-align=\"center\" align=\"center\" label=\"???\"></el-table-column>\n          <el-table-column prop=\"shifouquxiao\" header-align=\"center\" align=\"center\" label=\"????\"></el-table-column>\n          <el-table-column prop=\"jiage\" header-align=\"center\" align=\"center\" la