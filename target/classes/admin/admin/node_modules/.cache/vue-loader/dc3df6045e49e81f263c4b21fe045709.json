template>\n  <div class=\"addEdit-block\">\n    <el-form\n      class=\"detail-form-content\"\n      ref=\"ruleForm\"\n      :model=\"ruleForm\"\n      label-width=\"100px\"\n    >\n      <el-row>\n        <el-col :span=\"12\">\n          <el-form-item label=\"订单编号\">\n            <el-input v-model=\"ruleForm.dingdanbianhao\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"客房号\">\n            <el-input v-model=\"ruleForm.kefanghao\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"客房类型\">\n            <el-input v-model=\"ruleForm.kefangleixing\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"所属酒店\">\n            <el-input v-model=\"ruleForm.suoshujiudian\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"账号\">\n            <el-input v-model=\"ruleForm.zhanghao\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"姓名\">\n            <el-input v-model=\"ruleForm.xingming\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"取消原因\">\n            <el-input v-model=\"ruleForm.quxiaoyuanyin\" :readonly=\"type=='info'\"></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"取消时间\">\n            <el-input v-model=\"ruleForm.quxiaoshijian\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"审核状态\">\n            <el-input v-model=\"ruleForm.sfsh\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n        <el-col :span=\"12\">\n          <el-form-item label=\"审核回复\">\n            <el-input v-model=\"ruleForm.shhf\" readonly></el-input>\n          </el-form-item>\n        </el-col>\n      </el-row>\n      <el-form-item class=\"btn\">\n        <el-button @click=\"back()\">返回</el-button>\n      </el-form-item>\n    </el-form>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      ruleForm: {},\n      type: ''\n    };\n  },\n  props: ['parent'],\n  methods: {\n    init(id, type) {\n      this.type = type;\n      if (id) {\n        this.$http({\n          url: `yonghuquxiao/info/${id}`,\n          method: 'get'\n        }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.ruleForm = data.data;\n          }\n        });\n      }\n    },\n    back() {\n      this.parent.showFlag = true;\n      this.parent.addOrUpdateFlag = false;\n    }\n  }\n};\n</script>\n<style lang=\"scss\" scoped>\n.addEdit-block {\n  padding: 20px;\n}\n.btn {\n  text-align: center;\n  margin-top: 20px;\n}\n</style>\n"]}]}