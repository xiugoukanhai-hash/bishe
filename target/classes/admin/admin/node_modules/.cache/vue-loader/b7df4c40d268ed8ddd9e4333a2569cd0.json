     var ids = id ? [Number(id)] : this.dataListSelections.map(item => Number(item.id));\n      this.$confirm(\"?????????\", \"??\", {\n        confirmButtonText: \"??\",\n        cancelButtonText: \"??\",\n        type: \"warning\"\n      }).then(() => {\n        this.$http({\n          url: \"kefangxinxi/delete\",\n          method: \"post\",\n          data: ids\n        }).then(({ data }) => {\n          if (data && data.code === 0) {\n            this.$message({\n              message: \"????\",\n              type: \"success\",\n              duration: 1500,\n              onClose: () => {\n                this.search();\n              }\n            });\n          } else {\n            this.$message.error(data.msg);\n          }\n        });\n      });\n    }\n  }\n};\n</script>\n<style lang=\"scss\" scoped>\n.slt {\n  margin: 0 !important;\n  display: flex;\n}\n.ad {\n  margin: 0 !important;\n  display: flex;\n}\n.tables {\n  & ::v-deep .el-button {\n    margin: 4px;\n  }\n}\n</style>\n"]}]}