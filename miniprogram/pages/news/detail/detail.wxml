<view class="container">
  <!-- 文章头部 -->
  <view class="article-header">
    <text class="article-title">{{newsInfo.title || newsInfo.biaoti || '暂无标题'}}</text>
    <view class="article-meta">
      <text class="meta-time">{{newsInfo.addtime}}</text>
      <text class="meta-views">{{newsInfo.clicknum || 0}}阅读</text>
    </view>
  </view>

  <!-- 封面图 -->
  <image class="article-cover" src="{{newsInfo.imageUrl || newsInfo.picture || newsInfo.tupian}}" mode="aspectFill" wx:if="{{newsInfo.imageUrl || newsInfo.picture || newsInfo.tupian}}" />

  <!-- 文章内容 -->
  <view class="article-content">
    <rich-text class="rich-text" nodes="{{newsInfo.content || newsInfo.neirong || '<p>暂无内容</p>'}}" />
  </view>

  <!-- 加载状态 -->
  <loading show="{{loading}}" />
</view>
