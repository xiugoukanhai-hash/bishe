.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 支付金额卡片 */
.pay-info {
  background: linear-gradient(135deg, #1989fa 0%, #0d74d6 100%);
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.25);
}

.pay-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 16rpx;
}

.pay-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.currency {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 500;
  margin-right: 4rpx;
}

.amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 订单信息卡片 */
.order-info {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 支付方式 */
.pay-methods {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.method-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.method-item:last-child {
  margin-bottom: 0;
}

.method-item.active {
  border-color: #1989fa;
  background-color: #f0f7ff;
}

.method-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.method-icon-wrap.wechat {
  background: linear-gradient(135deg, #07c160 0%, #059c4d 100%);
}

.method-icon-wrap.balance {
  background: linear-gradient(135deg, #ff9500 0%, #ff7b00 100%);
}

.icon-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.method-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.method-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.balance-amount {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.method-check {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.method-check.checked {
  background-color: #1989fa;
  border-color: #1989fa;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

/* 余额不足样式 */
.method-item.insufficient {
  opacity: 0.8;
}

.balance-amount.red {
  color: #ff4d4f;
}

/* 充值提示 */
.recharge-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  margin-top: 8rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #999999;
}

.recharge-link {
  font-size: 26rpx;
  color: #1989fa;
  font-weight: 500;
}

/* 底部按钮 */
.btn-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.pay-btn {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa 0%, #0d74d6 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 20rpx rgba(25, 137, 250, 0.35);
}

.pay-btn.disabled {
  opacity: 0.6;
  box-shadow: none;
}
