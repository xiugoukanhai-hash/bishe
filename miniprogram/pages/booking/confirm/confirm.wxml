<view class="container">
  <!-- 房间信息 -->
  <view class="section">
    <view class="section-title">房间信息</view>
    <view class="section-content">
      <view class="room-info">
        <image class="room-image" src="{{roomInfo.imageUrl || '/images/default/room.png'}}" mode="aspectFill" />
        <view class="room-detail">
          <text class="room-name">{{roomInfo.kefanghao || '暂无'}}</text>
          <text class="room-type">{{roomInfo.kefangleixing || '标准房'}}</text>
          <view class="room-price">
            <text>¥{{roomInfo.jiage || 0}}</text>
            <text>/晚</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 入住日期 -->
  <view class="section">
    <view class="section-title">入住日期</view>
    <view class="section-content">
      <view class="date-row">
        <text class="date-label">入住日期</text>
        <picker class="date-picker" mode="date" value="{{checkInDate}}" start="{{minCheckInDate}}" end="2030-12-31" bindchange="bindCheckInChange">
          <text class="date-value">{{checkInDate || '请选择'}}</text>
          <text class="arrow">></text>
        </picker>
      </view>
      <view class="date-row">
        <text class="date-label">退房日期</text>
        <picker class="date-picker" mode="date" value="{{checkOutDate}}" start="{{minCheckOutDate || checkInDate}}" end="2030-12-31" bindchange="bindCheckOutChange">
          <text class="date-value">{{checkOutDate || '请选择'}}</text>
          <text class="arrow">></text>
        </picker>
      </view>
      <view class="date-row">
        <text class="date-label">入住天数</text>
        <text class="date-value">{{nights || 0}}晚</text>
      </view>
    </view>
  </view>

  <!-- 入住人信息 -->
  <view class="section guest-section">
    <view class="section-title">入住人信息</view>
    <view class="section-content">
      <view class="form-item">
        <text class="form-label">姓名</text>
        <view class="input-wrapper">
          <input class="form-input" placeholder="请输入入住人姓名" value="{{guestName}}" bindinput="onNameInput" always-embed="{{true}}" adjust-position="{{true}}" />
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <view class="input-wrapper">
          <input class="form-input" type="text" placeholder="请输入手机号" value="{{guestPhone}}" bindinput="onPhoneInput" maxlength="11" always-embed="{{true}}" adjust-position="{{true}}" />
        </view>
      </view>
      <view class="form-item">
        <text class="form-label">身份证</text>
        <view class="input-wrapper">
          <input class="form-input" type="text" placeholder="请输入身份证号" value="{{guestIdCard}}" bindinput="onIdCardInput" maxlength="18" always-embed="{{true}}" adjust-position="{{true}}" />
        </view>
      </view>
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="section">
    <view class="section-title">价格明细</view>
    <view class="section-content">
      <view class="price-row">
        <text class="price-label">房费（{{nights}}晚 x ¥{{roomInfo.jiage || 0}}）</text>
        <text class="price-value">¥{{roomPrice || 0}}</text>
      </view>
      <view class="price-row" wx:if="{{discount > 0}}">
        <text class="price-label">会员优惠</text>
        <text class="price-value">-¥{{discount}}</text>
      </view>
      <view class="price-row total">
        <text class="price-label">应付总额</text>
        <text class="price-value">¥{{totalPrice || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="total-price">
      <text class="total-label">应付：</text>
      <text class="total-amount">¥{{totalPrice || 0}}</text>
    </view>
    <button class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitOrder" disabled="{{!canSubmit}}">提交订单</button>
  </view>
</view>
