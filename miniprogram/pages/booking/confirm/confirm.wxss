.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 140rpx;
  position: relative;
  z-index: 1;
}

/* 尝试覆盖任何原生按钮覆盖层 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: -1;
}

/* 确保所有section在最上层 */
.section {
  position: relative;
  z-index: 10;
}

.section {
  background-color: #ffffff;
  margin-bottom: 24rpx;
}

.section-title {
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  border-bottom: 1rpx solid #ebedf0;
}

.section-content {
  padding: 24rpx;
}

/* 房间信息 */
.room-info {
  display: flex;
}

.room-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.room-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.room-type {
  font-size: 26rpx;
  color: #1989fa;
  margin-top: 8rpx;
}

.room-price {
  font-size: 36rpx;
  color: #ee0a24;
  font-weight: 600;
}

.room-price text {
  font-size: 24rpx;
  font-weight: normal;
}

/* 日期选择 */
.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.date-row:last-child {
  border-bottom: none;
}

.date-label {
  font-size: 28rpx;
  color: #646566;
}

.date-value {
  font-size: 28rpx;
  color: #323233;
}

.date-picker {
  display: flex;
  align-items: center;
}

.date-picker text {
  margin-right: 8rpx;
}

.arrow {
  font-size: 24rpx;
  color: #969799;
}

/* 入住人信息 */
.guest-section {
  position: relative;
  z-index: 100;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
  z-index: 101;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #646566;
  flex-shrink: 0;
}

.input-wrapper {
  flex: 1;
  position: relative;
  z-index: 102;
  background-color: #ffffff;
}

.form-input {
  width: 100%;
  font-size: 28rpx;
  color: #323233;
  background-color: #ffffff;
}

/* 价格明细 */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #646566;
}

.price-value {
  font-size: 28rpx;
  color: #323233;
}

.price-row.total {
  border-top: 1rpx solid #ebedf0;
  padding-top: 24rpx;
  margin-top: 8rpx;
}

.price-row.total .price-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.price-row.total .price-value {
  font-size: 36rpx;
  color: #ee0a24;
  font-weight: 600;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #646566;
  margin-right: 8rpx;
}

.total-amount {
  font-size: 40rpx;
  color: #ee0a24;
  font-weight: 600;
}

.submit-btn {
  min-width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 40rpx;
}

.submit-btn.disabled {
  background: #c8c9cc;
}
