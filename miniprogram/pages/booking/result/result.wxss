.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
}

.result-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.result-icon.success {
  color: #07c160;
  font-size: 120rpx;
}

.result-icon.fail {
  color: #ee0a24;
  font-size: 120rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #969799;
}

.order-info {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: #646566;
}

.info-value {
  color: #323233;
}

.btn-area {
  display: flex;
  padding: 40rpx 0;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  margin: 0 12rpx;
}

.btn-default {
  background-color: #ffffff;
  color: #323233;
  border: 1rpx solid #dcdee0;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #ffffff;
}
