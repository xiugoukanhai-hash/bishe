/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #969799;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 功能入口 */
.func-grid {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background-color: #ffffff;
  margin-bottom: 24rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.func-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.func-text {
  font-size: 26rpx;
  color: #323233;
}

.func-item:active {
  opacity: 0.7;
}

/* 区块样式 */
.section {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #1989fa 0%, #1476d9 100%);
  border-radius: 3rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #969799;
}

.more-arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 4rpx;
}

/* 酒店简介 */
.hotel-intro {
  background: linear-gradient(135deg, #e8f4ff 0%, #d4e9ff 100%);
  border-radius: 16rpx;
  margin: 0 24rpx 24rpx;
}

.hotel-content {
  display: flex;
  flex-direction: column;
}

.hotel-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1989fa;
  margin-bottom: 12rpx;
}

.hotel-desc {
  font-size: 26rpx;
  color: #646566;
  line-height: 1.6;
}

/* 客房列表 */
.room-list {
  display: flex;
  flex-direction: column;
}

/* 资讯列表 */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:active {
  background-color: #fafafa;
}

.news-image {
  width: 180rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: #f7f8fa;
}

.news-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.news-title {
  font-size: 28rpx;
  color: #323233;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.news-time {
  font-size: 24rpx;
  color: #969799;
}

/* 底部留白 */
.footer-space {
  height: 40rpx;
}
