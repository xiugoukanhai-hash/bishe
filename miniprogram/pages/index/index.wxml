<!--
  首页
  展示搜索栏、轮播图、功能入口、热门房间、资讯等
-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goSearch">
    <view class="search-input">
      <image class="search-icon" src="/images/icons/search.png" mode="aspectFit" />
      <text class="search-placeholder">搜索房间类型、房号...</text>
    </view>
  </view>
  
  <!-- 轮播图 -->
  <swiper 
    class="banner-swiper" 
    autoplay="{{true}}" 
    interval="{{4000}}" 
    circular="{{true}}"
    indicator-dots="{{true}}"
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#ffffff"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerClick" data-item="{{item}}">
      <image class="banner-image" src="{{item.imageUrl || '/images/default/banner.png'}}" mode="aspectFill" binderror="onBannerImageError" data-index="{{index}}" />
    </swiper-item>
  </swiper>
  
  <!-- 功能入口 -->
  <view class="func-grid">
    <view class="func-item" bindtap="goRoomList">
      <image class="func-icon" src="/images/icons/room.png" mode="aspectFit" />
      <text class="func-text">客房预订</text>
    </view>
    <view class="func-item" bindtap="goOrderList">
      <image class="func-icon" src="/images/icons/order.png" mode="aspectFit" />
      <text class="func-text">我的订单</text>
    </view>
    <view class="func-item" bindtap="goAIService">
      <image class="func-icon" src="/images/icons/service.png" mode="aspectFit" />
      <text class="func-text">智能客服</text>
    </view>
    <view class="func-item" bindtap="goNews">
      <image class="func-icon" src="/images/icons/news.png" mode="aspectFit" />
      <text class="func-text">酒店资讯</text>
    </view>
  </view>
  
  <!-- 酒店简介 -->
  <view class="section hotel-intro" wx:if="{{hotelInfo}}">
    <view class="section-header">
      <text class="section-title">酒店简介</text>
    </view>
    <view class="hotel-content">
      <text class="hotel-name">{{hotelInfo.name || '酒店住房管理系统'}}</text>
      <text class="hotel-desc">{{hotelInfo.content || '为您提供舒适、便捷的住宿体验'}}</text>
    </view>
  </view>
  
  <!-- 热门客房 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门客房</text>
      <view class="section-more" bindtap="goRoomList">
        <text>查看更多</text>
        <image class="more-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="room-list">
      <room-card 
        wx:for="{{hotRooms}}" 
        wx:key="id" 
        room="{{item}}"
        showStatus="{{true}}"
        bindclick="goRoomDetail"
      />
    </view>
    <empty 
      wx:if="{{!loading && hotRooms.length === 0}}"
      type="empty-data"
      text="暂无热门客房"
    />
  </view>
  
  <!-- 最新资讯 -->
  <view class="section" wx:if="{{newsList.length > 0}}">
    <view class="section-header">
      <text class="section-title">最新资讯</text>
      <view class="section-more" bindtap="goNews">
        <text>更多</text>
        <image class="more-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="news-list">
      <view 
        class="news-item" 
        wx:for="{{newsList}}" 
        wx:key="id" 
        bindtap="goNewsDetail"
        data-id="{{item.id}}"
      >
        <image class="news-image" src="{{item.imageUrl || '/images/default/news.png'}}" mode="aspectFill" binderror="onNewsImageError" data-index="{{index}}" />
        <view class="news-info">
          <text class="news-title">{{item.title}}</text>
          <text class="news-time">{{item.addtime}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>

<!-- 加载状态 -->
<loading show="{{loading}}" fullscreen="{{true}}" text="加载中..." />
