.container {
  min-height: 100vh;
  background-color: #f7f8fa;
}

/* 积分卡片 */
.points-card {
  background: linear-gradient(135deg, #1989fa, #07c160);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  color: #ffffff;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.points-rules {
  font-size: 24rpx;
  opacity: 0.8;
}

.points-value {
  font-size: 72rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.points-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  background-color: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  color: #1989fa;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #323233;
}

/* 积分明细 */
.section {
  background-color: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.view-all {
  font-size: 26rpx;
  color: #1989fa;
}

.section-content {
  padding: 0 24rpx;
}

/* 积分记录 */
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #969799;
}

.record-value {
  font-size: 32rpx;
  font-weight: 600;
}

.record-value.income {
  color: #07c160;
}

.record-value.expense {
  color: #ee0a24;
}

/* 积分任务 */
.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.task-item:last-child {
  border-bottom: none;
}

.task-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: #e8f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1989fa;
  margin-right: 24rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 4rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #969799;
}

.task-points {
  font-size: 26rpx;
  color: #ff976a;
  margin-right: 16rpx;
}

.task-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 24rpx;
}

.task-btn.done {
  background: #c8c9cc;
}
