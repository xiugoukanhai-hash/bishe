<!--
  个人中心页
-->
<view class="container">
  <!-- 顶部背景 -->
  <view class="header-bg" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <!-- 用户信息区域 -->
    <view class="user-section">
      <!-- 未登录 -->
      <view class="user-info not-login" wx:if="{{!isLoggedIn}}" bindtap="goLogin">
        <image class="avatar default" src="/images/default/avatar.png" mode="aspectFill" />
        <view class="user-detail">
          <text class="username">点击登录</text>
          <text class="user-desc">登录后享受更多服务</text>
        </view>
        <image class="arrow-icon" src="/images/icons/arrow-right-white.png" mode="aspectFit" />
      </view>
      
      <!-- 已登录 -->
      <view class="user-info logged-in" wx:else>
        <image 
          class="avatar" 
          src="{{userInfo.avatarUrl || '/images/default/avatar.png'}}" 
          mode="aspectFill"
          bindtap="goEditInfo"
        />
        <view class="user-detail">
          <view class="username-row">
            <text class="username">{{userInfo.xingming || userInfo.username || '用户'}}</text>
            <view class="member-tag" wx:if="{{isMember}}">
              <text>会员</text>
            </view>
          </view>
          <text class="user-phone" wx:if="{{userInfo.shouji}}">{{maskedPhone}}</text>
        </view>
        <view class="settings-btn" bindtap="goEditInfo">
          <image class="settings-icon" src="/images/icons/edit-white.png" mode="aspectFit" />
        </view>
      </view>
      
      <!-- 余额和积分卡片 -->
      <view class="wallet-card" wx:if="{{isLoggedIn}}">
        <view class="wallet-item" bindtap="goRecharge">
          <text class="wallet-label">账户余额</text>
          <view class="wallet-value-row">
            <text class="wallet-value">¥{{balance || '0.00'}}</text>
            <text class="wallet-action">充值</text>
          </view>
        </view>
        <view class="wallet-divider"></view>
        <view class="wallet-item" wx:if="{{isMember}}" bindtap="goPoints">
          <text class="wallet-label">会员积分</text>
          <view class="wallet-value-row">
            <text class="wallet-value">{{userInfo.jifen || 0}}</text>
            <text class="wallet-action">明细</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 订单入口 -->
  <view class="order-section card">
    <view class="section-header" bindtap="goOrderList">
      <text class="section-title">我的订单</text>
      <view class="section-more">
        <text>查看全部</text>
        <image class="arrow-icon small" src="/images/icons/arrow-right.png" mode="aspectFit" />
      </view>
    </view>
    <view class="order-grid">
      <view class="order-item" bindtap="goOrderList" data-tab="1">
        <view class="order-icon-wrapper">
          <image class="order-icon" src="/images/icons/order-pending.png" mode="aspectFit" />
          <view class="badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
        </view>
        <text class="order-text">待支付</text>
      </view>
      <view class="order-item" bindtap="goOrderList" data-tab="2">
        <view class="order-icon-wrapper">
          <image class="order-icon" src="/images/icons/order-paid.png" mode="aspectFit" />
          <view class="badge" wx:if="{{orderCounts.paid > 0}}">{{orderCounts.paid}}</view>
        </view>
        <text class="order-text">已支付</text>
      </view>
      <view class="order-item" bindtap="goOrderList" data-tab="3">
        <view class="order-icon-wrapper">
          <image class="order-icon" src="/images/icons/order-completed.png" mode="aspectFit" />
        </view>
        <text class="order-text">已完成</text>
      </view>
      <view class="order-item" bindtap="goEvaluateList">
        <view class="order-icon-wrapper">
          <image class="order-icon" src="/images/icons/order-evaluate.png" mode="aspectFit" />
          <view class="badge" wx:if="{{orderCounts.toEvaluate > 0}}">{{orderCounts.toEvaluate}}</view>
        </view>
        <text class="order-text">待评价</text>
      </view>
    </view>
  </view>
  
  <!-- 功能列表 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="goCollect">
      <image class="menu-icon" src="/images/icons/collect.png" mode="aspectFit" />
      <text class="menu-text">我的收藏</text>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goMessage">
      <image class="menu-icon" src="/images/icons/message.png" mode="aspectFit" />
      <text class="menu-text">消息通知</text>
      <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goAIService">
      <image class="menu-icon" src="/images/icons/ai-service.png" mode="aspectFit" />
      <text class="menu-text">智能客服</text>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="goFAQ">
      <image class="menu-icon" src="/images/icons/faq.png" mode="aspectFit" />
      <text class="menu-text">常见问题</text>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
  </view>
  
  
  <!-- 账号设置 -->
  <view class="menu-section card" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goPassword">
      <image class="menu-icon" src="/images/icons/password.png" mode="aspectFit" />
      <text class="menu-text">修改密码</text>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
    <view class="menu-item" bindtap="onLogout">
      <image class="menu-icon" src="/images/icons/logout.png" mode="aspectFit" />
      <text class="menu-text text-danger">退出登录</text>
      <image class="menu-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" />
    </view>
  </view>
  
  <!-- 底部留白 -->
  <view class="footer-space"></view>
</view>
