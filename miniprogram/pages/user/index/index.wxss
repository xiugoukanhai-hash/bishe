/* 顶部背景 */
.header-bg {
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
  padding-bottom: 40rpx;
}

/* 用户区域 */
.user-section {
  padding: 0 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar.default {
  background-color: rgba(255, 255, 255, 0.2);
}

.user-detail {
  flex: 1;
  min-width: 0;
}

.username-row {
  display: flex;
  align-items: center;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.member-tag {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  border-radius: 20rpx;
}

.member-tag text {
  font-size: 22rpx;
  color: #8B4513;
  font-weight: 600;
}

.user-desc,
.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}

.arrow-icon.small {
  width: 24rpx;
  height: 24rpx;
}

.settings-btn {
  padding: 16rpx;
}

.settings-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 钱包卡片（余额+积分） */
.wallet-card {
  display: flex;
  align-items: stretch;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-top: 16rpx;
}

.wallet-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
}

.wallet-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.wallet-value-row {
  display: flex;
  align-items: baseline;
}

.wallet-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.wallet-action {
  font-size: 22rpx;
  color: #ffd700;
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 215, 0, 0.2);
  border-radius: 16rpx;
}

.wallet-divider {
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 8rpx 0;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 24rpx;
  margin-top: 0;
  overflow: hidden;
}

/* 订单区域 */
.order-section {
  margin-top: -20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #969799;
}

.order-grid {
  display: flex;
  padding: 24rpx 0;
}

.order-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon-wrapper {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.order-icon {
  width: 100%;
  height: 100%;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #ffffff;
  background-color: #ee0a24;
  border-radius: 16rpx;
  text-align: center;
}

.order-text {
  font-size: 24rpx;
  color: #646566;
}

/* 菜单区域 */
.menu-section {
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #fafafa;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
}

.menu-text.text-danger {
  color: #ee0a24;
}

.menu-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  color: #ffffff;
  background-color: #ee0a24;
  border-radius: 18rpx;
  text-align: center;
  margin-right: 16rpx;
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
}

.menu-hint {
  font-size: 22rpx;
  color: #999999;
  margin-right: 16rpx;
}

/* 底部留白 */
.footer-space {
  height: 40rpx;
}
