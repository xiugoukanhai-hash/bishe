.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  position: relative;
  z-index: 1;
}

.form-section {
  background-color: #ffffff;
  margin-bottom: 24rpx;
}

/* 头像 */
.avatar-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.avatar-label {
  font-size: 28rpx;
  color: #323233;
}

.avatar-wrapper {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.avatar-arrow {
  font-size: 24rpx;
  color: #969799;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #323233;
  flex-shrink: 0;
}

.input-wrapper {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  position: relative;
  z-index: 100;
}

.form-input {
  width: 100%;
  font-size: 28rpx;
  color: #323233;
  text-align: right;
  background-color: transparent;
  border: none;
  outline: none;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
  text-align: right;
}

.form-placeholder {
  color: #c8c9cc;
}

.form-arrow {
  font-size: 24rpx;
  color: #969799;
  margin-left: 8rpx;
}

/* 性别选择 */
.gender-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

/* 日期选择 */
.date-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

/* 保存按钮 */
.btn-area {
  padding: 40rpx 24rpx;
}

.save-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 44rpx;
}
