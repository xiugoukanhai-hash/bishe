<view class="container">
  <!-- 头像 -->
  <view class="form-section">
    <view class="avatar-item" bindtap="chooseAvatar">
      <text class="avatar-label">头像</text>
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatarUrl || userInfo.touxiang || '/images/default/avatar.png'}}" mode="aspectFill" binderror="onAvatarError" />
        <text class="avatar-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{userInfo.xingming}}" bindinput="onNicknameInput" always-embed="{{true}}" />
    </view>
    <view class="form-item">
      <text class="form-label">性别</text>
      <picker class="gender-picker" mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="form-value {{userInfo.xingbie ? '' : 'form-placeholder'}}">
          {{userInfo.xingbie || '请选择'}}
          <text class="form-arrow">></text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 联系信息 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input 
        class="form-input" 
        type="text"
        placeholder="请输入手机号" 
        value="{{userInfo.shouji}}" 
        bindinput="onPhoneInput" 
        maxlength="11"
        always-embed="{{true}}"
      />
    </view>
    <view class="form-item">
      <text class="form-label">身份证</text>
      <input 
        class="form-input" 
        type="text"
        placeholder="请输入身份证号" 
        value="{{userInfo.shenfenzheng}}" 
        bindinput="onIdCardInput" 
        maxlength="18"
        always-embed="{{true}}"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="save-btn" bindtap="saveInfo">保存</button>
  </view>
</view>
