.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding-bottom: 180rpx;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #1989fa 0%, #07c160 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  color: #ffffff;
}

.balance-info {
  margin-bottom: 20rpx;
}

.balance-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.balance-value {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.balance-value .currency {
  font-size: 36rpx;
  font-weight: 600;
}

.balance-value .amount {
  font-size: 72rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

.member-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.points-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.bonus-tip {
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 区块 */
.section {
  background-color: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 金额选择网格 */
.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.amount-item.active {
  background-color: #e6f4ff;
  border-color: #1989fa;
}

.amount-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.amount-item.active .amount-text {
  color: #1989fa;
}

.bonus-text {
  font-size: 22rpx;
  color: #ff6b00;
  margin-top: 8rpx;
}

/* 自定义金额输入 */
.custom-input-wrap {
  display: flex;
  align-items: center;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
}

.currency-prefix {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.custom-input {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
}

/* 提示说明 */
.tips-section {
  margin: 24rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
}

.tip-item {
  font-size: 24rpx;
  color: #999999;
  line-height: 2;
}

/* 底部按钮栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.recharge-info {
  display: flex;
  align-items: baseline;
}

.recharge-label {
  font-size: 28rpx;
  color: #666666;
}

.recharge-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff4d4f;
  margin-left: 8rpx;
}

.recharge-btn {
  min-width: 240rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa 0%, #07c160 100%);
  border-radius: 44rpx;
  border: none;
}

.recharge-btn.disabled {
  background: #cccccc;
}

.recharge-btn::after {
  border: none;
}
