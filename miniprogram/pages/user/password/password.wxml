<view class="container">
  <!-- 密码表单 -->
  <view class="form-card">
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input class="form-input" type="password" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" always-embed="{{true}}" />
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input class="form-input" type="password" placeholder="请输入新密码（6-20位）" value="{{newPassword}}" bindinput="onNewPasswordInput" always-embed="{{true}}" />
    </view>
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input class="form-input" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" always-embed="{{true}}" />
    </view>
  </view>

  <!-- 密码强度 -->
  <view class="password-strength" wx:if="{{newPassword}}">
    <text class="strength-label">密码强度</text>
    <view class="strength-bar">
      <view class="strength-level weak {{passwordStrength >= 1 ? 'active' : ''}}"></view>
      <view class="strength-level medium {{passwordStrength >= 2 ? 'active' : ''}}"></view>
      <view class="strength-level strong {{passwordStrength >= 3 ? 'active' : ''}}"></view>
    </view>
    <text class="strength-text">{{strengthText}}</text>
  </view>

  <!-- 提示信息 -->
  <view class="tips">
    <text class="tips-title">密码设置建议：</text>
    <text class="tips-item">· 长度为6-20位字符</text>
    <text class="tips-item">· 建议使用字母、数字和符号的组合</text>
    <text class="tips-item">· 避免使用连续数字或相同字符</text>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-area">
    <button class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitPassword" disabled="{{!canSubmit}}">确认修改</button>
  </view>

  <!-- 加载状态 -->
  <loading show="{{loading}}" />
</view>
