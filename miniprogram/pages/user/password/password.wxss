.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
}

.form-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #323233;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
}

.input-placeholder {
  color: #c8c9cc;
}

/* 密码强度指示 */
.password-strength {
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
}

.strength-label {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 16rpx;
}

.strength-bar {
  display: flex;
  height: 8rpx;
  background-color: #ebedf0;
  border-radius: 4rpx;
  overflow: hidden;
}

.strength-level {
  flex: 1;
  margin-right: 8rpx;
}

.strength-level:last-child {
  margin-right: 0;
}

.strength-level.weak.active {
  background-color: #ee0a24;
}

.strength-level.medium.active {
  background-color: #ff976a;
}

.strength-level.strong.active {
  background-color: #07c160;
}

.strength-text {
  text-align: center;
  font-size: 24rpx;
  color: #969799;
  margin-top: 12rpx;
}

/* 提示信息 */
.tips {
  padding: 24rpx;
  margin-top: 24rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #c8c9cc;
  line-height: 1.8;
}

/* 提交按钮 */
.btn-area {
  padding: 48rpx 0;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background: #c8c9cc;
}
