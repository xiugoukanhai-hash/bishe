.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 编辑模式 */
.edit-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ebedf0;
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #323233;
}

.checkbox {
  margin-right: 12rpx;
}

.edit-btn {
  font-size: 28rpx;
  color: #1989fa;
}

/* 收藏列表 */
.collect-list {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.collect-item {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-checkbox {
  display: flex;
  align-items: center;
  padding: 24rpx;
  padding-right: 0;
}

.room-card {
  flex: 1;
  display: flex;
  padding: 24rpx;
}

.room-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  background-color: #f7f8fa;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.room-type {
  font-size: 26rpx;
  color: #1989fa;
  margin-top: 8rpx;
}

.room-price {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
}

.price-value {
  font-size: 36rpx;
  color: #ee0a24;
  font-weight: 600;
}

.price-unit {
  font-size: 24rpx;
  color: #969799;
  margin-left: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #323233;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 48rpx;
}

.empty-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #1989fa;
  background-color: #ffffff;
  border: 2rpx solid #1989fa;
  border-radius: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.selected-info {
  font-size: 28rpx;
  color: #323233;
}

.selected-count {
  color: #1989fa;
  font-weight: 600;
}

.delete-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #ee0a24;
  border-radius: 32rpx;
}

.delete-btn.disabled {
  background-color: #c8c9cc;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #969799;
}
