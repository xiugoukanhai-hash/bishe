.container {
  min-height: 100vh;
  background-color: #f7f8fa;
}

/* 类型筛选 */
.type-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 24rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.type-tab {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #646566;
  background-color: #f7f8fa;
  border-radius: 32rpx;
  margin-right: 24rpx;
}

.type-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
}

/* 消息列表 */
.message-list {
  padding: 24rpx;
}

.message-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-item.read {
  opacity: 0.7;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.message-type {
  display: flex;
  align-items: center;
}

.type-tag {
  font-size: 24rpx;
  color: #1989fa;
  background-color: #ecf5ff;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #ee0a24;
  border-radius: 50%;
  margin-left: 12rpx;
}

.message-time {
  font-size: 24rpx;
  color: #c8c9cc;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  display: block;
  margin-bottom: 12rpx;
}

.message-content {
  font-size: 26rpx;
  color: #646566;
  line-height: 1.6;
  display: block;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebedf0;
}

.delete-btn {
  font-size: 26rpx;
  color: #ee0a24;
  padding: 8rpx 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #323233;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #969799;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #969799;
}
