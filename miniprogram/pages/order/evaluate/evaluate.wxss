.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
}

.room-info {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  margin-bottom: 24rpx;
}

.room-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.room-detail {
  flex: 1;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 8rpx;
}

.room-type {
  font-size: 26rpx;
  color: #1989fa;
}

.evaluate-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 16rpx;
}

.rating-area {
  display: flex;
  align-items: center;
}

.rating-value {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ff976a;
}

.textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #323233;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.image-upload {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: #ee0a24;
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
  line-height: 36rpx;
  border-radius: 50%;
}

.add-image {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #dcdee0;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #dcdee0;
}

.add-text {
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 44rpx;
  margin-top: 40rpx;
}
