/* 未登录 */
.not-login {
  padding-top: 100rpx;
}

/* Tab栏 */
.tab-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ebedf0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 20rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #646566;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #1989fa;
  font-weight: 600;
}

.tab-line-inner {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
  border-radius: 3rpx;
}

/* 订单滚动列表 */
.order-scroll {
  height: calc(100vh - 100rpx);
}

.order-list {
  padding: 24rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #969799;
}
