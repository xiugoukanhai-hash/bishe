.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding-bottom: 160rpx;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1989fa;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 订单状态卡片 */
.status-card {
  padding: 48rpx 32rpx;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-card.pending {
  background: linear-gradient(135deg, #ff9500 0%, #ff7b00 100%);
}

.status-card.paid {
  background: linear-gradient(135deg, #1989fa 0%, #0d74d6 100%);
}

.status-card.checkedin {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.status-card.completed {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.status-card.cancelled {
  background: linear-gradient(135deg, #8c8c8c 0%, #595959 100%);
}

.status-card.refunding {
  background: linear-gradient(135deg, #fa8c16 0%, #d46b08 100%);
}

.status-card.refunded {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
}

.status-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 房间信息卡片 */
.room-card {
  background-color: #ffffff;
  margin: -32rpx 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
}

.room-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.room-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.room-header {
  display: flex;
  align-items: center;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 12rpx;
}

.room-type {
  font-size: 22rpx;
  color: #1989fa;
  background-color: #e6f4ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.date-info {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.date-text {
  font-size: 26rpx;
  color: #666666;
}

.night-tag {
  font-size: 22rpx;
  color: #666666;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
}

/* 信息区块 */
.section {
  background-color: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-content {
  padding: 16rpx 28rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 价格明细 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.price-row.total {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  margin-top: 8rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-row.total .price-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.price-value {
  font-size: 28rpx;
  color: #333333;
}

.price-value.highlight {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: 700;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn {
  min-width: 180rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 38rpx;
  margin-left: 20rpx;
}

.btn-default {
  background-color: #ffffff;
  color: #333333;
  border: 1rpx solid #d9d9d9;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa 0%, #0d74d6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

.btn-danger {
  background-color: #ffffff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
}
