.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 40rpx 32rpx;
}

.form-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #ebedf0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1989fa;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 60rpx;
  color: #1989fa;
  font-size: 26rpx;
}

.btn-area {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #ffffff;
}

.btn-disabled {
  background: #c8c9cc;
}

.footer-links {
  text-align: center;
}

.link {
  color: #1989fa;
  font-size: 28rpx;
}
