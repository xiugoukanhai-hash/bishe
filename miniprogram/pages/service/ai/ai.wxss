.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  display: flex;
  flex-direction: column;
}

/* 顶部状态栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.ai-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 16rpx;
}

.chat-area {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.chat-area.with-top-bar {
  padding-top: 16rpx;
}

.message-item {
  margin-bottom: 32rpx;
}

.message-item.user {
  display: flex;
  justify-content: flex-end;
}

.message-item.ai {
  display: flex;
  justify-content: flex-start;
}

.message-bubble {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-item.user .message-bubble {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #ffffff;
  border-bottom-right-radius: 4rpx;
}

.message-item.ai .message-bubble {
  background-color: #ffffff;
  color: #323233;
  border-bottom-left-radius: 4rpx;
}

/* AI头像 */
.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 正在输入 */
.typing-indicator {
  display: flex;
  align-items: center;
  padding: 16rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #969799;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-8rpx);
  }
}

/* 快捷问题 */
.quick-questions {
  padding: 24rpx;
  background-color: #ffffff;
}

.quick-title {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
}

.quick-item {
  padding: 12rpx 24rpx;
  background-color: #f7f8fa;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #323233;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
}

/* 输入区 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-field {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #f7f8fa;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 36rpx;
}

.send-btn.disabled {
  background: #c8c9cc;
}
