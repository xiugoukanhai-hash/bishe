.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  display: flex;
  flex-direction: column;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ebedf0;
}

.tip-text {
  font-size: 24rpx;
  color: #969799;
}

.top-bar .actions {
  display: flex;
  gap: 24rpx;
}

.top-bar .action-btn {
  font-size: 24rpx;
  color: #646566;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background-color: #f7f8fa;
}

.top-bar .action-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.message-item {
  margin-bottom: 32rpx;
}

.message-item.self {
  display: flex;
  flex-direction: row-reverse;
}

.message-item.other {
  display: flex;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #eee;
}

.message-item.self .avatar {
  margin-left: 16rpx;
}

.message-item.other .avatar {
  margin-right: 16rpx;
}

.message-content {
  max-width: 65%;
}

.message-name {
  font-size: 24rpx;
  color: #969799;
  margin-bottom: 8rpx;
  display: block;
}

.message-item.self .message-name {
  text-align: right;
}

.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.message-item.self .message-bubble {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #ffffff;
  border-bottom-right-radius: 4rpx;
}

.message-item.other .message-bubble {
  background-color: #ffffff;
  color: #323233;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-time {
  font-size: 22rpx;
  color: #c8c9cc;
  margin-top: 8rpx;
  display: block;
}

.message-item.self .message-time {
  text-align: right;
}

/* 输入区 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: flex-end;
}

.input-field {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  padding: 16rpx 24rpx;
  background-color: #f7f8fa;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 36rpx;
  padding: 0;
}

.send-btn.disabled {
  background: #c8c9cc;
}

/* 正在输入动画 */
.typing-indicator .message-bubble.typing {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
}

.typing-indicator .dot {
  font-size: 48rpx;
  line-height: 1;
  color: #969799;
  animation: typing 1.4s infinite;
}

.typing-indicator .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-indicator .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    opacity: 0.3;
    transform: translateY(0);
  }
  30% {
    opacity: 1;
    transform: translateY(-8rpx);
  }
}
