.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 120rpx;
}

.search-area {
  padding: 24rpx;
  background-color: #ffffff;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f7f8fa;
  padding: 16rpx 24rpx;
  border-radius: 36rpx;
}

.search-icon {
  font-size: 28rpx;
  font-weight: bold;
  color: #1989fa;
  margin-right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: #e8f4ff;
  border-radius: 8rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  padding: 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ebedf0;
  overflow-x: auto;
  white-space: nowrap;
}

.category-tab {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #646566;
  background-color: #f7f8fa;
  border-radius: 24rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.category-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
}

/* 问题列表 */
.faq-list {
  padding: 24rpx;
}

.faq-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  font-size: 28rpx;
  color: #323233;
}

.question-text {
  flex: 1;
  display: flex;
  align-items: flex-start;
}

.question-icon {
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.expand-icon {
  font-size: 32rpx;
  color: #969799;
  transition: transform 0.3s;
  flex-shrink: 0;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

.faq-answer {
  display: none;
  padding: 0 24rpx 24rpx;
  font-size: 26rpx;
  color: #646566;
  line-height: 1.8;
  background-color: #f7f8fa;
}

.faq-answer.show {
  display: flex;
  align-items: flex-start;
}

.answer-icon {
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
  background-color: #07c160;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #323233;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #969799;
}

/* 联系客服 */
.contact-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.contact-tip {
  font-size: 26rpx;
  color: #969799;
  margin-right: 24rpx;
}

.contact-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1989fa, #07c160);
  border-radius: 32rpx;
}
