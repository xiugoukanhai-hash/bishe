<!--
  客房列表页
-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <image class="search-icon" src="/images/icons/search.png" mode="aspectFit" />
      <input 
        class="search-input" 
        type="text" 
        placeholder="搜索房号、类型、价格..." 
        value="{{keyword}}"
        focus="{{autoFocus}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        always-embed="{{true}}"
        adjust-position="{{true}}"
      />
      <image 
        class="clear-icon" 
        src="/images/icons/close-circle.png" 
        mode="aspectFit"
        wx:if="{{keyword}}"
        bindtap="clearKeyword"
      />
    </view>
  </view>
  
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{currentFilter === 'type' ? 'active' : ''}}" 
      bindtap="showTypeFilter"
    >
      <text>{{selectedType || '房间类型'}}</text>
      <image class="filter-arrow" src="/images/icons/arrow-down.png" mode="aspectFit" />
    </view>
    <view 
      class="filter-item {{currentFilter === 'price' ? 'active' : ''}}" 
      bindtap="togglePriceSort"
    >
      <text>价格</text>
      <image 
        class="filter-arrow {{priceSort}}" 
        src="/images/icons/sort.png" 
        mode="aspectFit" 
      />
    </view>
    <view 
      class="filter-item {{onlyAvailable ? 'active' : ''}}" 
      bindtap="toggleAvailable"
    >
      <text>仅看可订</text>
    </view>
  </view>
  
  <!-- 房间列表 -->
  <scroll-view 
    class="room-scroll"
    scroll-y="{{true}}"
    lower-threshold="100"
    bindscrolltolower="loadMore"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="room-list">
      <room-card 
        wx:for="{{roomList}}" 
        wx:key="id" 
        room="{{item}}"
        showStatus="{{true}}"
        showAction="{{true}}"
        bindclick="goRoomDetail"
      />
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{roomList.length > 0}}">
      <loading wx:if="{{loadingMore}}" show="{{true}}" type="dots" text="加载中..." />
      <text wx:elif="{{noMore}}" class="no-more-text">已经到底了</text>
    </view>
    
    <!-- 空状态 -->
    <empty 
      wx:if="{{!loading && roomList.length === 0}}"
      type="empty-search"
      text="{{keyword ? '未找到相关房间' : '暂无客房'}}"
      description="{{keyword ? '换个关键词试试吧' : ''}}"
      showButton="{{!!keyword}}"
      buttonText="清空搜索"
      bindbuttonclick="clearKeyword"
    />
  </scroll-view>
</view>

<!-- 房型筛选弹窗 -->
<view class="filter-popup {{showTypePopup ? 'show' : ''}}" catchtouchmove="preventMove">
  <view class="popup-mask" bindtap="hideTypeFilter"></view>
  <view class="popup-content">
    <view class="popup-header">
      <text class="popup-title">选择房间类型</text>
      <text class="popup-reset" bindtap="resetTypeFilter">重置</text>
    </view>
    <view class="type-list">
      <view 
        class="type-item {{selectedType === '' ? 'active' : ''}}" 
        bindtap="selectType" 
        data-type=""
      >全部</view>
      <view 
        class="type-item {{selectedType === item ? 'active' : ''}}" 
        wx:for="{{roomTypes}}" 
        wx:key="*this"
        bindtap="selectType" 
        data-type="{{item}}"
      >{{item}}</view>
    </view>
  </view>
</view>

<!-- 全局加载 -->
<loading show="{{loading}}" fullscreen="{{true}}" text="加载中..." />
