<view class="container">
  <!-- 用户类型切换 -->
  <view class="type-switch">
    <view 
      class="type-item {{userType === 'user' ? 'active' : ''}}" 
      data-type="user"
      bindtap="switchUserType"
    >
      <text class="type-text">普通用户</text>
    </view>
    <view 
      class="type-item {{userType === 'member' ? 'active' : ''}}" 
      data-type="member"
      bindtap="switchUserType"
    >
      <text class="type-text">会员注册</text>
      <text class="type-badge">享优惠</text>
    </view>
  </view>
  
  <!-- 注册表单 -->
  <view class="form-section">
    <!-- 账号 -->
    <view class="form-item">
      <view class="form-label required">账号</view>
      <input 
        class="form-input" 
        placeholder="4-20位字母、数字或下划线" 
        maxlength="20"
        value="{{form.username}}"
        bindinput="onUsernameInput"
        always-embed="{{true}}"
      />
    </view>
    
    <!-- 密码 -->
    <view class="form-item">
      <view class="form-label required">密码</view>
      <view class="form-input-wrapper">
        <input 
          class="form-input" 
          password="{{!showPassword}}"
          placeholder="6-20位密码" 
          maxlength="20"
          value="{{form.password}}"
          bindinput="onPasswordInput"
          always-embed="{{true}}"
        />
        <view class="password-toggle" bindtap="togglePassword">
          <text>{{showPassword ? '隐藏' : '显示'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 确认密码 -->
    <view class="form-item">
      <view class="form-label required">确认密码</view>
      <input 
        class="form-input" 
        password="{{!showPassword}}"
        placeholder="请再次输入密码" 
        maxlength="20"
        value="{{form.confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        always-embed="{{true}}"
      />
    </view>
    
    <!-- 分隔线 -->
    <view class="form-divider"></view>
    
    <!-- 姓名 -->
    <view class="form-item">
      <view class="form-label required">姓名</view>
      <input 
        class="form-input" 
        placeholder="请输入真实姓名" 
        maxlength="20"
        value="{{form.xingming}}"
        bindinput="onNameInput"
        always-embed="{{true}}"
      />
    </view>
    
    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label required">手机号</view>
      <input 
        class="form-input" 
        type="text"
        maxlength="11"
        placeholder="请输入11位手机号" 
        value="{{form.shouji}}"
        bindinput="onPhoneInput"
        always-embed="{{true}}"
      />
    </view>
    
    <!-- 身份证号 -->
    <view class="form-item">
      <view class="form-label required">身份证号</view>
      <input 
        class="form-input" 
        type="text"
        maxlength="18"
        placeholder="请输入18位身份证号" 
        value="{{form.shenfenzheng}}"
        bindinput="onIdCardInput"
        always-embed="{{true}}"
      />
    </view>
    
    <!-- 性别 -->
    <view class="form-item">
      <view class="form-label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <view class="form-picker">
          <text>{{form.xingbie}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    
    <!-- 年龄 -->
    <view class="form-item">
      <view class="form-label">年龄</view>
      <input 
        class="form-input" 
        type="number"
        maxlength="3"
        placeholder="选填" 
        value="{{form.nianling}}"
        bindinput="onAgeInput"
        always-embed="{{true}}"
      />
    </view>
  </view>
  
  <!-- 会员权益提示 -->
  <view class="member-tips" wx:if="{{userType === 'member'}}">
    <view class="tips-title">会员专属权益</view>
    <view class="tips-list">
      <view class="tips-item">
        <text class="tips-icon">✓</text>
        <text>预订享95折优惠</text>
      </view>
      <view class="tips-item">
        <text class="tips-icon">✓</text>
        <text>消费1元累计1积分</text>
      </view>
      <view class="tips-item">
        <text class="tips-icon">✓</text>
        <text>评价奖励10积分</text>
      </view>
    </view>
  </view>
  
  <!-- 协议同意 -->
  <view class="agreement">
    <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgreement">
      <text wx:if="{{agreed}}">✓</text>
    </view>
    <view class="agreement-text">
      <text>我已阅读并同意</text>
      <text class="link" bindtap="goUserAgreement">《用户协议》</text>
      <text>和</text>
      <text class="link" bindtap="goPrivacy">《隐私政策》</text>
    </view>
  </view>
  
  <!-- 注册按钮 -->
  <view class="btn-area">
    <button 
      class="btn btn-primary {{canSubmit ? '' : 'btn-disabled'}}" 
      disabled="{{!canSubmit || submitting}}"
      loading="{{submitting}}"
      bindtap="onSubmit"
    >
      {{userType === 'member' ? '注册会员' : '注册'}}
    </button>
  </view>
  
  <!-- 底部链接 -->
  <view class="footer">
    <text>已有账号？</text>
    <text class="link" bindtap="goLogin">立即登录</text>
  </view>
</view>
