.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 用户类型切换 */
.type-switch {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.type-item.active {
  background: linear-gradient(135deg, #1989fa, #07c160);
}

.type-text {
  font-size: 28rpx;
  color: #646566;
}

.type-item.active .type-text {
  color: #ffffff;
  font-weight: 500;
}

.type-badge {
  font-size: 20rpx;
  color: #ff976a;
  margin-top: 4rpx;
}

.type-item.active .type-badge {
  color: rgba(255, 255, 255, 0.9);
}

/* 表单区域 */
.form-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: #ee0a24;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #ebedf0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1989fa;
}

.form-input-wrapper {
  position: relative;
}

.form-input-wrapper .form-input {
  padding-right: 100rpx;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #1989fa;
  font-size: 26rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #ebedf0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 24rpx;
  color: #969799;
}

.form-divider {
  height: 1rpx;
  background-color: #ebedf0;
  margin: 32rpx 0;
}

/* 会员权益 */
.member-tips {
  background: linear-gradient(135deg, #fff7e8, #fffbe8);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff976a;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-wrap: wrap;
}

.tips-item {
  width: 50%;
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.tips-icon {
  color: #07c160;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tips-item text:last-child {
  font-size: 24rpx;
  color: #646566;
}

/* 协议 */
.agreement {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #dcdee0;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: #1989fa;
  border-color: #1989fa;
  color: #ffffff;
  font-size: 24rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #969799;
  line-height: 1.6;
}

.link {
  color: #1989fa;
}

/* 按钮区域 */
.btn-area {
  margin-bottom: 32rpx;
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #ffffff;
}

.btn-disabled {
  background: #c8c9cc;
}

/* 底部 */
.footer {
  text-align: center;
  font-size: 28rpx;
  color: #969799;
}

.footer .link {
  margin-left: 8rpx;
}
