.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #646566;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-desc {
  font-size: 26rpx;
  color: #969799;
  margin-bottom: 32rpx;
  text-align: center;
  line-height: 1.5;
  padding: 0 40rpx;
}

.empty-button {
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  margin-top: 16rpx;
}

.empty-button-primary {
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
  color: #ffffff;
  border: none;
}

.empty-button-default {
  background-color: #ffffff;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}

.empty-button-hover {
  opacity: 0.85;
  transform: scale(0.98);
}
