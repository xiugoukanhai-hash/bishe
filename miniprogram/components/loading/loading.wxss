/* 全屏遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

/* 行内加载 */
.loading-inline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 加载动画容器 */
.loading-spinner {
  position: relative;
  width: 64rpx;
  height: 64rpx;
}

.loading-spinner.inline {
  margin-right: 16rpx;
}

/* 圆点旋转加载（spinner） */
.loading-spinner.spinner {
  animation: none;
}

.spinner-dot {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background-color: #1989fa;
  border-radius: 50%;
  animation: spinner-fade 1.2s linear infinite;
}

/* 12个点的位置计算 */
.spinner-dot:nth-child(1) { top: 0; left: 50%; margin-left: -5rpx; animation-delay: 0s; }
.spinner-dot:nth-child(2) { top: 8rpx; left: 77%; margin-left: -5rpx; animation-delay: -0.1s; }
.spinner-dot:nth-child(3) { top: 27rpx; left: 93%; margin-left: -5rpx; animation-delay: -0.2s; }
.spinner-dot:nth-child(4) { top: 50%; left: 100%; margin-top: -5rpx; margin-left: -10rpx; animation-delay: -0.3s; }
.spinner-dot:nth-child(5) { top: 73%; left: 93%; margin-left: -5rpx; animation-delay: -0.4s; }
.spinner-dot:nth-child(6) { top: 92%; left: 77%; margin-left: -5rpx; animation-delay: -0.5s; }
.spinner-dot:nth-child(7) { bottom: 0; left: 50%; margin-left: -5rpx; animation-delay: -0.6s; }
.spinner-dot:nth-child(8) { top: 92%; left: 23%; margin-left: -5rpx; animation-delay: -0.7s; }
.spinner-dot:nth-child(9) { top: 73%; left: 7%; margin-left: -5rpx; animation-delay: -0.8s; }
.spinner-dot:nth-child(10) { top: 50%; left: 0; margin-top: -5rpx; animation-delay: -0.9s; }
.spinner-dot:nth-child(11) { top: 27%; left: 7%; margin-left: -5rpx; animation-delay: -1.0s; }
.spinner-dot:nth-child(12) { top: 8rpx; left: 23%; margin-left: -5rpx; animation-delay: -1.1s; }

@keyframes spinner-fade {
  0%, 39%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* 圆环旋转加载（circular） */
.circular-ring {
  width: 100%;
  height: 100%;
  border: 4rpx solid #e5e5e5;
  border-top-color: #1989fa;
  border-radius: 50%;
  animation: circular-spin 0.8s linear infinite;
}

@keyframes circular-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 跳动点加载（dots） */
.dots-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.bounce-dot {
  width: 16rpx;
  height: 16rpx;
  margin: 0 6rpx;
  background-color: #1989fa;
  border-radius: 50%;
  animation: bounce-dot 1.4s ease-in-out infinite;
}

.bounce-dot:nth-child(1) { animation-delay: -0.32s; }
.bounce-dot:nth-child(2) { animation-delay: -0.16s; }
.bounce-dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce-dot {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 加载文字 */
.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #646566;
}

.loading-text.inline {
  margin-top: 0;
  margin-left: 8rpx;
}
