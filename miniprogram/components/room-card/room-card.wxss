/* 水平布局（默认） */
.room-card.horizontal {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.room-card.horizontal .room-image-wrapper {
  position: relative;
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.room-card.horizontal .room-image {
  width: 100%;
  height: 100%;
}

.room-card.horizontal .room-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

/* 垂直布局 */
.room-card.vertical {
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.room-card.vertical .room-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.room-card.vertical .room-image {
  width: 100%;
  height: 100%;
}

.room-card.vertical .room-info {
  padding: 20rpx 24rpx;
}

/* 房间状态标签 */
.room-status-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.room-status-tag.available {
  color: #07c160;
  background-color: rgba(255, 255, 255, 0.95);
}

.room-status-tag.occupied {
  color: #ee0a24;
  background-color: rgba(255, 255, 255, 0.95);
}

.room-status-tag.cleaning {
  color: #ff976a;
  background-color: rgba(255, 255, 255, 0.95);
}

.room-status-tag.maintenance {
  color: #969799;
  background-color: rgba(255, 255, 255, 0.95);
}

.room-status-tag.reserved {
  color: #1989fa;
  background-color: rgba(255, 255, 255, 0.95);
}

.room-status-tag.unavailable {
  color: #969799;
  background-color: rgba(255, 255, 255, 0.95);
}

/* 收藏按钮 */
.collect-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
}

.collect-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 房间头部 */
.room-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-type-tag {
  font-size: 22rpx;
  color: #1989fa;
  background-color: #e8f4ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* 标签 */
.room-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.room-tag {
  font-size: 22rpx;
  color: #969799;
  margin-right: 16rpx;
}

.room-tag::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  background-color: #dcdee0;
  border-radius: 50%;
  margin-right: 8rpx;
  vertical-align: middle;
}

/* 设施标签 */
.room-facilities {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.facility-tag {
  font-size: 22rpx;
  color: #646566;
  background-color: #f7f8fa;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* 底部 */
.room-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.room-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ee0a24;
  font-weight: 500;
}

.price-value {
  font-size: 40rpx;
  color: #ee0a24;
  font-weight: 600;
  margin: 0 4rpx;
  line-height: 1;
}

.price-unit {
  font-size: 22rpx;
  color: #969799;
}

.price-original {
  font-size: 22rpx;
  color: #c8c9cc;
  text-decoration: line-through;
  margin-left: 12rpx;
}

/* 操作按钮 */
.room-action {
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
}

.action-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 点击效果 */
.room-card:active {
  opacity: 0.9;
}
