.order-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.status-text {
  font-size: 26rpx;
  font-weight: 600;
}

.status-text.status-pending {
  color: #ff9500;
}

.status-text.status-paid {
  color: #1989fa;
}

.status-text.status-checkedin {
  color: #52c41a;
  font-weight: 700;
}

.status-text.status-completed {
  color: #07c160;
}

.status-text.status-cancelled {
  color: #999999;
}

.status-text.status-refunding {
  color: #fa8c16;
  font-weight: 700;
}

.status-text.status-refunded {
  color: #722ed1;
  font-weight: 700;
}

/* 内容区 */
.order-content {
  display: flex;
  padding: 20rpx 24rpx;
}

.room-image {
  width: 140rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.room-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.room-type {
  font-size: 24rpx;
  color: #1989fa;
  margin-bottom: 6rpx;
}

.check-date {
  font-size: 24rpx;
  color: #999999;
}

/* 底部 */
.order-footer {
  display: flex;
  flex-direction: column;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  background-color: #fafafa;
}

.price-area {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 8rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff4d4f;
}

/* 按钮区域 */
.action-area {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  white-space: nowrap;
  flex-shrink: 0;
  min-width: 120rpx;
}

.btn-default {
  background-color: #ffffff;
  color: #666666;
  border: 1rpx solid #dcdcdc;
}

.btn-primary {
  background-color: #1989fa;
  color: #ffffff;
  border: none;
}

.btn::after {
  border: none;
}

/* 点击效果 */
.order-card:active {
  opacity: 0.95;
}
