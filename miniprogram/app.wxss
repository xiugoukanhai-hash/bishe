.m-0 { margin: 0; }
.m-8 { margin: 8rpx; }
.m-16 { margin: 16rpx; }
.m-24 { margin: 24rpx; }
.m-32 { margin: 32rpx; }

.mt-0 { margin-top: 0; }
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }

.mb-0 { margin-bottom: 0; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.mb-48 { margin-bottom: 48rpx; }

.ml-0 { margin-left: 0; }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }
.ml-24 { margin-left: 24rpx; }
.ml-32 { margin-left: 32rpx; }

.mr-0 { margin-right: 0; }
.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }
.mr-24 { margin-right: 24rpx; }
.mr-32 { margin-right: 32rpx; }

.mx-auto { margin-left: auto; margin-right: auto; }

/* Padding */
.p-0 { padding: 0; }
.p-8 { padding: 8rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

.pt-0 { padding-top: 0; }
.pt-8 { padding-top: 8rpx; }
.pt-16 { padding-top: 16rpx; }
.pt-24 { padding-top: 24rpx; }
.pt-32 { padding-top: 32rpx; }

.pb-0 { padding-bottom: 0; }
.pb-8 { padding-bottom: 8rpx; }
.pb-16 { padding-bottom: 16rpx; }
.pb-24 { padding-bottom: 24rpx; }
.pb-32 { padding-bottom: 32rpx; }

.pl-0 { padding-left: 0; }
.pl-8 { padding-left: 8rpx; }
.pl-16 { padding-left: 16rpx; }
.pl-24 { padding-left: 24rpx; }
.pl-32 { padding-left: 32rpx; }

.pr-0 { padding-right: 0; }
.pr-8 { padding-right: 8rpx; }
.pr-16 { padding-right: 16rpx; }
.pr-24 { padding-right: 24rpx; }
.pr-32 { padding-right: 32rpx; }

.px-16 { padding-left: 16rpx; padding-right: 16rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }

.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-24 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-32 { padding-top: 32rpx; padding-bottom: 32rpx; }

/* ============================================
   卡片样式
   ============================================ */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-shadow {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-border {
  border: 1rpx solid var(--border-color);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

/* ============================================
   按钮样式
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa 0%, #1476d9 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-success {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
}

.btn-success:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-danger {
  background: linear-gradient(135deg, #ee0a24 0%, #d40920 100%);
  color: #ffffff;
}

.btn-danger:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-warning {
  background: linear-gradient(135deg, #ff976a 0%, #f58b58 100%);
  color: #ffffff;
}

.btn-outline {
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
  background-color: #ffffff;
}

.btn-outline:active {
  background-color: var(--primary-color-light);
}

.btn-outline-gray {
  border: 2rpx solid var(--border-color);
  color: var(--text-color-secondary);
  background-color: #ffffff;
}

.btn-outline-gray:active {
  background-color: var(--background-color);
}

.btn-text {
  background-color: transparent;
  color: var(--primary-color);
  height: auto;
  padding: 0;
}

.btn-disabled {
  background-color: #c8c9cc !important;
  color: #ffffff !important;
  cursor: not-allowed;
  pointer-events: none;
}

.btn-small {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
}

.btn-mini {
  height: 48rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
}

.btn-block {
  width: 100%;
}

.btn-round {
  border-radius: 44rpx;
}

.btn-square {
  border-radius: 8rpx;
}

/* ============================================
   分割线
   ============================================ */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background-color: var(--border-color);
  margin: 0 16rpx;
}

/* ============================================
   标签样式
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 4rpx;
}

.tag-primary {
  color: var(--primary-color);
  background-color: var(--primary-color-light);
}

.tag-success {
  color: var(--success-color);
  background-color: var(--success-color-light);
}

.tag-danger {
  color: var(--danger-color);
  background-color: var(--danger-color-light);
}

.tag-warning {
  color: var(--warning-color);
  background-color: var(--warning-color-light);
}

.tag-gray {
  color: var(--text-color-placeholder);
  background-color: var(--background-color);
}

/* ============================================
   表单样式
   ============================================ */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.form-label-required::before {
  content: '*';
  color: var(--danger-color);
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary-color);
}

.form-input-error {
  border-color: var(--danger-color);
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-error {
  font-size: 24rpx;
  color: var(--danger-color);
  margin-top: 8rpx;
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-color-placeholder);
  margin-top: 8rpx;
}

/* ============================================
   列表样式
   ============================================ */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: var(--background-color);
}

.list-item-arrow::after {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid var(--text-color-placeholder);
  border-right: 2rpx solid var(--text-color-placeholder);
  transform: rotate(45deg);
  margin-left: auto;
}

/* ============================================
   价格样式
   ============================================ */
.price {
  color: var(--danger-color);
  font-weight: 600;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 500;
}

.price-value {
  font-size: 36rpx;
}

.price-unit {
  font-size: 22rpx;
  color: var(--text-color-placeholder);
  font-weight: normal;
}

.price-original {
  font-size: 24rpx;
  color: var(--text-color-placeholder);
  text-decoration: line-through;
  font-weight: normal;
}

/* ============================================
   状态标签
   ============================================ */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 4rpx;
}

.status-available {
  color: var(--success-color);
  background-color: var(--success-color-light);
}

.status-occupied {
  color: var(--danger-color);
  background-color: var(--danger-color-light);
}

.status-pending {
  color: var(--warning-color);
  background-color: var(--warning-color-light);
}

.status-completed {
  color: var(--text-color-placeholder);
  background-color: var(--background-color);
}

/* ============================================
   安全区域
   ============================================ */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* 固定底部操作栏 */
.fixed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.05);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

/* 为固定底部预留空间 */
.has-fixed-bottom {
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ============================================
   骨架屏
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #f2f3f5 25%, #e6e6e6 37%, #f2f3f5 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

.skeleton-text {
  height: 28rpx;
  border-radius: 4rpx;
}

.skeleton-title {
  height: 40rpx;
  border-radius: 4rpx;
  width: 60%;
}

.skeleton-image {
  border-radius: 8rpx;
}

.skeleton-avatar {
  border-radius: 50%;
}

.skeleton-button {
  height: 88rpx;
  border-radius: 44rpx;
}

/* ============================================
   工具类
   ============================================ */
.w-full {
  width: 100%;
}

.h-full {
  height: 100%;
}

.min-h-screen {
  min-height: 100vh;
}

.overflow-hidden {
  overflow: hidden;
}

.overflow-auto {
  overflow: auto;
}

.overflow-scroll {
  overflow: scroll;
  -webkit-overflow-scrolling: touch;
}

.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.fixed {
  position: fixed;
}

.hidden {
  display: none;
}

.block {
  display: block;
}

.inline-block {
  display: inline-block;
}

.rounded {
  border-radius: 8rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-full {
  border-radius: 50%;
}

.border {
  border: 1rpx solid var(--border-color);
}

.border-b {
  border-bottom: 1rpx solid var(--border-color);
}

.border-t {
  border-top: 1rpx solid var(--border-color);
}

.bg-white {
  background-color: #ffffff;
}

.bg-gray {
  background-color: var(--background-color);
}

.bg-primary {
  background-color: var(--primary-color);
}

/* ============================================
   动画类
   ============================================ */
.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.slide-up {
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* ============================================
   页面过渡占位
   ============================================ */
.page-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

/* ============================================
   图片占位
   ============================================ */
.img-placeholder {
  background-color: var(--background-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.img-placeholder::before {
  content: '';
  width: 60rpx;
  height: 60rpx;
  background-color: var(--border-color);
  border-radius: 4rpx;
}

/* ============================================
   表单输入框确保在最高层级
   ============================================ */
.form-input {
  position: relative;
  z-index: 100;
}

.form-item {
  position: relative;
  z-index: 100;
}

/* 确保页面容器有正确的堆叠上下文 */
.container {
  position: relative;
  z-index: 1;
}
